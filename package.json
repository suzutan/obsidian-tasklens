    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.3",
    "htm": "^3.1.1",
    "lefthook": "^2.1.3",
    "obsidian": "latest",
    "oxlint": "^1.51.0",
    "preact": "^10.25.4",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
